<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#F4EBD0" />
            <stroke android:width="3dp" android:color="#1976D2" />
        </shape>
    </item>

    <!-- Flower Decorations -->
    <item android:width="24dp" android:height="24dp" android:gravity="top|start"
        android:left="4dp" android:top="4dp"
        android:drawable="@drawable/ic_flower_corner" />

    <item android:width="24dp" android:height="24dp" android:gravity="top|end"
        android:right="4dp" android:top="4dp">
        <rotate android:fromDegrees="90" android:drawable="@drawable/ic_flower_corner" />
    </item>

    <!-- Inner Border -->
    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="0.5dp" android:color="#64B5F6" />
        </shape>
    </item>
</layer-list>