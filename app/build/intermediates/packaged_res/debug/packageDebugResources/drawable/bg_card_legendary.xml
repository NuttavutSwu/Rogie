<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#F4EBD0" />
            <stroke android:width="4dp" android:color="#FFD700" />
        </shape>
    </item>

    <!-- Dragon Corner Decorations (Gold) -->
    <item android:width="40dp" android:height="40dp" android:gravity="top|start"
        android:left="2dp" android:top="2dp"
        android:drawable="@drawable/ic_dragon_corner" />

    <item android:width="40dp" android:height="40dp" android:gravity="top|end"
        android:right="2dp" android:top="2dp">
        <rotate android:fromDegrees="90" android:drawable="@drawable/ic_dragon_corner" />
    </item>

    <item android:width="40dp" android:height="40dp" android:gravity="bottom|start"
        android:left="2dp" android:bottom="2dp">
        <rotate android:fromDegrees="270" android:drawable="@drawable/ic_dragon_corner" />
    </item>

    <item android:width="40dp" android:height="40dp" android:gravity="bottom|end"
        android:right="2dp" android:bottom="2dp">
        <rotate android:fromDegrees="180" android:drawable="@drawable/ic_dragon_corner" />
    </item>

    <!-- Red Seal Signature -->
    <item android:width="24dp" android:height="24dp" android:gravity="bottom|end"
        android:right="14dp" android:bottom="14dp"
        android:drawable="@drawable/ic_seal_signature" />

    <!-- Decorative Inner Border -->
    <item android:top="14dp" android:bottom="14dp" android:left="14dp" android:right="14dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#FFA000" />
        </shape>
    </item>
</layer-list>