<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="@drawable/bg_scroll"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvNodeInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/scroll_ink" />

    <TextView
        android:id="@+id/tvNodeRarity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNodeState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/scroll_ink"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnUnlockNode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/unlock_talent" />
</LinearLayout>
