<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Parchment Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#F4EBD0" />
            <stroke android:width="3dp" android:color="#1976D2" />
        </shape>
    </item>

    <!-- Decorative Inner Border -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="#64B5F6" />
        </shape>
    </item>
</layer-list>