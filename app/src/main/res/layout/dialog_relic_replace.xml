<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/scroll_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ช่องเก็บวัตถุโบราณเต็ม!"
        android:textColor="@color/scroll_ink"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="กรุณาเลือกวัตถุโบราณ 1 ชิ้นเพื่อทิ้งและแทนที่ด้วยชิ้นใหม่"
        android:textColor="@color/scroll_ink"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/llRelicChoices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/tvNewRelicInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="#3E2723"
        android:textStyle="italic" />

</LinearLayout>
